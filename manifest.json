{
  "id": "hunyuan3d2mv",
  "name": "Hunyuan3D-2mv",
  "type": "model",
  "source": "https://github.com/iammojogo-sudo/hunyuan3d2mv_development_branch",
  "description": "Multi-view image-to-3D mesh generation using Tencent Hunyuan3D-2mv. Accepts front, left, back and right view images to reconstruct a detailed untextured mesh. Only the front view is required.",
  "version": "1.1.0",
  "author": "Lightning Pixel",
  "vram_gb": 8,
  "tags": [
    "image-to-3d",
    "multi-view",
    "mesh"
  ],
  "nodes": [
    {
      "id": "generate",
      "name": "Generate Mesh",
      "inputs": [
        "image",
        "image",
        "image",
        "image"
      ],
      "hf_repo": "tencent/Hunyuan3D-2mv",
      "download_check": "hunyuan3d-dit-v2-mv-turbo/model.fp16.safetensors",
      "hf_skip_prefixes": [
        "hunyuan3d-dit-v2-mv/model.fp16.ckpt",
        "hunyuan3d-dit-v2-mv-turbo/model.fp16.ckpt",
        "hunyuan3d-dit-v2-mv-fast/model.fp16.ckpt"
      ],
      "params_schema": [
        {
          "id": "model_variant",
          "label": "Model Variant",
          "type": "select",
          "default": "hunyuan3d-dit-v2-mv-turbo",
          "options": [
            {
              "value": "hunyuan3d-dit-v2-mv-turbo",
              "label": "Turbo"
            },
            {
              "value": "hunyuan3d-dit-v2-mv-fast",
              "label": "Fast"
            },
            {
              "value": "hunyuan3d-dit-v2-mv",
              "label": "Standard"
            }
          ],
          "tooltip": "Select the model variant for mesh generation."
        },
        {
          "id": "num_inference_steps",
          "label": "Inference Steps",
          "type": "select",
          "default": 30,
          "options": [
            {
              "value": 10,
              "label": "Fast (10)"
            },
            {
              "value": 30,
              "label": "Balanced (30)"
            },
            {
              "value": 50,
              "label": "Quality (50)"
            }
          ],
          "tooltip": "Number of diffusion steps."
        },
        {
          "id": "octree_resolution",
          "label": "Mesh Resolution",
          "type": "select",
          "default": 380,
          "options": [
            {
              "value": 256,
              "label": "Low (256)"
            },
            {
              "value": 380,
              "label": "Medium (380)"
            },
            {
              "value": 512,
              "label": "High (512)"
            }
          ],
          "tooltip": "Octree resolution. Higher values use more VRAM."
        },
        {
          "id": "guidance_scale",
          "label": "Guidance Scale",
          "type": "select",
          "default": "5.0",
          "options": [
            {
              "value": "1.0",
              "label": "Loose (1.0)"
            },
            {
              "value": "5.0",
              "label": "Default (5.0)"
            },
            {
              "value": "7.5",
              "label": "Strong (7.5)"
            },
            {
              "value": "10.0",
              "label": "Tight (10.0)"
            }
          ],
          "tooltip": "Classifier-free guidance strength."
        },
        {
          "id": "num_chunks",
          "label": "Decode Chunks",
          "type": "select",
          "default": 8000,
          "options": [
            {
              "value": 2000,
              "label": "Low VRAM (2000)"
            },
            {
              "value": 8000,
              "label": "Balanced (8000)"
            },
            {
              "value": 20000,
              "label": "Fast (20000)"
            }
          ],
          "tooltip": "VAE decode chunk size. Lower values reduce VRAM usage."
        },
        {
          "id": "box_v",
          "label": "Bounding Box Scale",
          "type": "select",
          "default": "1.01",
          "options": [
            {
              "value": "0.75",
              "label": "Small (0.75)"
            },
            {
              "value": "1.01",
              "label": "Default (1.01)"
            },
            {
              "value": "1.25",
              "label": "Large (1.25)"
            }
          ],
          "tooltip": "Increase if mesh edges are clipped."
        },
        {
          "id": "mc_level",
          "label": "Surface Level",
          "type": "select",
          "default": "0.0",
          "options": [
            {
              "value": "-0.05",
              "label": "Thicker (-0.05)"
            },
            {
              "value": "0.0",
              "label": "Default (0.0)"
            },
            {
              "value": "0.05",
              "label": "Thinner (0.05)"
            }
          ],
          "tooltip": "Marching-cubes iso-surface level."
        },
        {
          "id": "remove_bg",
          "label": "Remove Background",
          "type": "select",
          "default": "true",
          "options": [
            {
              "value": "true",
              "label": "Yes"
            },
            {
              "value": "false",
              "label": "No"
            }
          ],
          "tooltip": "Run rembg before generation."
        },
        {
          "id": "left_image_path",
          "label": "Left View Image",
          "type": "string",
          "default": "",
          "pickerIntent": "image",
          "filters": [
            {
              "name": "Images",
              "extensions": [
                "png",
                "jpg",
                "jpeg",
                "webp"
              ]
            }
          ],
          "tooltip": "Optional left-side view image path."
        },
        {
          "id": "back_image_path",
          "label": "Back View Image",
          "type": "string",
          "default": "",
          "pickerIntent": "image",
          "filters": [
            {
              "name": "Images",
              "extensions": [
                "png",
                "jpg",
                "jpeg",
                "webp"
              ]
            }
          ],
          "tooltip": "Optional back view image path."
        },
        {
          "id": "right_image_path",
          "label": "Right View Image",
          "type": "string",
          "default": "",
          "pickerIntent": "image",
          "filters": [
            {
              "name": "Images",
              "extensions": [
                "png",
                "jpg",
                "jpeg",
                "webp"
              ]
            }
          ],
          "tooltip": "Optional right-side view image path."
        },
        {
          "id": "seed",
          "label": "Seed",
          "type": "int",
          "default": 42,
          "min": 0,
          "max": 4294967295,
          "tooltip": "Change if result is unsatisfying."
        }
      ],
      "output": "mesh",
      "input": "image"
    },
    {
      "id": "texture",
      "name": "Apply Texture",
      "type": "process",
      "entry": "processor.js",
      "input": "mesh",
      "output": "mesh",
      "hf_repo": "tencent/Hunyuan3D-2",
      "download_check": "hunyuan3d-delight-v2-0",
      "hf_skip_prefixes": [
        "hunyuan3d-dit-v2-0/",
        "hunyuan3d-dit-v2-0/*",
        "hunyuan3d-dit-v2-0-turbo/",
        "hunyuan3d-dit-v2-0-turbo/*",
        "hunyuan3d-dit-v2-0-fast/",
        "hunyuan3d-dit-v2-0-fast/*"
      ],
      "params_schema": [
        {
          "id": "front_image_path",
          "label": "Front View Image",
          "type": "string",
          "default": "",
          "pickerIntent": "image",
          "filters": [
            {
              "name": "Images",
              "extensions": [
                "png",
                "jpg",
                "jpeg",
                "webp"
              ]
            }
          ],
          "tooltip": "Required. The front view image used to drive texture generation."
        },
        {
          "id": "texture_variant",
          "label": "Texture Model",
          "type": "select",
          "default": "hunyuan3d-paint-v2-0-turbo",
          "options": [
            {
              "value": "hunyuan3d-paint-v2-0-turbo",
              "label": "Turbo (faster)"
            },
            {
              "value": "hunyuan3d-paint-v2-0",
              "label": "Standard (higher quality)"
            }
          ],
          "tooltip": "Turbo is faster; Standard produces more detailed textures."
        },
        {
          "id": "remove_bg",
          "label": "Remove Background",
          "type": "select",
          "default": "true",
          "options": [
            {
              "value": "true",
              "label": "Yes"
            },
            {
              "value": "false",
              "label": "No"
            }
          ],
          "tooltip": "Run rembg on reference images before texturing."
        },
        {
          "id": "left_image_path",
          "label": "Left View Image",
          "type": "string",
          "default": "",
          "pickerIntent": "image",
          "filters": [
            {
              "name": "Images",
              "extensions": [
                "png",
                "jpg",
                "jpeg",
                "webp"
              ]
            }
          ],
          "tooltip": "Optional. Extra views improve texture coverage."
        },
        {
          "id": "back_image_path",
          "label": "Back View Image",
          "type": "string",
          "default": "",
          "pickerIntent": "image",
          "filters": [
            {
              "name": "Images",
              "extensions": [
                "png",
                "jpg",
                "jpeg",
                "webp"
              ]
            }
          ],
          "tooltip": "Optional. Extra views improve texture coverage."
        },
        {
          "id": "right_image_path",
          "label": "Right View Image",
          "type": "string",
          "default": "",
          "pickerIntent": "image",
          "filters": [
            {
              "name": "Images",
              "extensions": [
                "png",
                "jpg",
                "jpeg",
                "webp"
              ]
            }
          ],
          "tooltip": "Optional. Extra views improve texture coverage."
        }
      ]
    }
  ],
  "generator_class": "Hunyuan3D2mvGenerator"
}
